---
import '../styles/site.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Membership – Fleet and District Dog Training Society</title>
  <meta name="description" content="Join Fleet and District Dog Training Society. Membership fees from £2. Runs January to December. Fleet, Hampshire." />
</head>
<body>

  <!-- Preview banner -->
  <div class="bg-[#34260A] text-white text-center text-sm py-2 px-4">
    Preview redesign for Fleet and District Dog Training Society by
    <a href="https://biscuitweb.co.uk/activate?id=P2432&name=Fleet%20and%20District%20Dog%20Training%20Society" class="underline font-semibold hover:text-amber-300">Biscuit Web</a>
  </div>

  <!-- Navigation -->
  <header class="bg-white border-b border-[#C2BEB6] sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-4 flex items-center justify-between h-16">
      <a href="/P2432" class="font-display font-800 text-[#34260A] text-lg leading-tight">
        Fleet &amp; District<br class="hidden sm:block" /> <span class="text-sm font-600">Dog Training Society</span>
      </a>
      <nav class="hidden md:flex items-center gap-6 text-sm font-semibold text-[#1F1706]">
        <a href="/P2432" class="hover:text-[#34260A] transition-colors">Home</a>
        <a href="/P2432/about-us-html" class="hover:text-[#34260A] transition-colors">About Us</a>
        <a href="/P2432/membership-html" class="text-[#34260A] border-b-2 border-[#34260A] pb-0.5">Membership</a>
        <a href="/P2432/obedience-html" class="hover:text-[#34260A] transition-colors">Obedience</a>
        <a href="/P2432/ringcraft-html" class="hover:text-[#34260A] transition-colors">Ringcraft</a>
        <a href="/P2432/contact-html" class="bg-[#34260A] text-white px-4 py-1.5 rounded-full hover:bg-[#2A1E08] transition-colors">Contact</a>
      </nav>
      <button id="menu-btn" class="md:hidden p-2 rounded text-[#34260A]" aria-label="Open menu">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
    <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-[#C2BEB6] px-4 py-4 flex flex-col gap-3 text-sm font-semibold text-[#1F1706]">
      <a href="/P2432" class="hover:text-[#34260A]">Home</a>
      <a href="/P2432/about-us-html" class="hover:text-[#34260A]">About Us</a>
      <a href="/P2432/membership-html" class="text-[#34260A]">Membership</a>
      <a href="/P2432/obedience-html" class="hover:text-[#34260A]">Obedience</a>
      <a href="/P2432/ringcraft-html" class="hover:text-[#34260A]">Ringcraft</a>
      <a href="/P2432/contact-html" class="hover:text-[#34260A]">Contact</a>
    </div>
  </header>

  <!-- Page hero -->
  <section class="relative overflow-hidden min-h-[280px] flex items-end">
    <img
      src="/P2432/images/membership-html-0.jpg"
      alt="Membership at Fleet and District Dog Training Society"
      class="absolute inset-0 w-full h-full object-cover"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-black/70"></div>
    <div class="relative z-10 max-w-6xl mx-auto px-6 py-10 w-full">
      <h1 class="text-white text-4xl font-800">Membership</h1>
      <p class="text-white/80 mt-2">Fleet &amp; District Dog Training Society</p>
    </div>
  </section>

  <!-- Membership content -->
  <section class="bg-[#F5F4F3] py-16 px-4">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-12 items-start">
      <div>
        <h2 class="text-[#34260A] text-2xl font-800 mb-4">Membership of Fleet &amp; District Dog Training Society</h2>
        <p class="text-[#1F1706] mb-6">Membership runs from <strong>1st January to 31st December</strong>.</p>

        <!-- Pricing table -->
        <div class="bg-white rounded-2xl border border-[#C2BEB6] overflow-hidden mb-6">
          <div class="bg-[#34260A] text-white px-6 py-3">
            <h3 class="font-800 text-lg">Annual Membership Fees</h3>
          </div>
          <div class="divide-y divide-[#EFEEEB]">
            <div class="flex justify-between items-center px-6 py-4">
              <div>
                <p class="font-semibold text-[#1F1706]">Junior</p>
                <p class="text-sm text-[#1F1706]/70">Under 16 years old</p>
              </div>
              <span class="text-[#34260A] font-800 text-xl">£2.00</span>
            </div>
            <div class="flex justify-between items-center px-6 py-4">
              <div>
                <p class="font-semibold text-[#1F1706]">Single</p>
                <p class="text-sm text-[#1F1706]/70">One adult</p>
              </div>
              <span class="text-[#34260A] font-800 text-xl">£5.00</span>
            </div>
            <div class="flex justify-between items-center px-6 py-4">
              <div>
                <p class="font-semibold text-[#1F1706]">Joint</p>
                <p class="text-sm text-[#1F1706]/70">Two adults</p>
              </div>
              <span class="text-[#34260A] font-800 text-xl">£8.00</span>
            </div>
            <div class="flex justify-between items-center px-6 py-4">
              <div>
                <p class="font-semibold text-[#1F1706]">Family</p>
                <p class="text-sm text-[#1F1706]/70">Two adults and their children under 16</p>
              </div>
              <span class="text-[#34260A] font-800 text-xl">£10.00</span>
            </div>
          </div>
        </div>

        <div class="bg-[#EFEEEB] rounded-xl p-5 border border-[#C2BEB6]">
          <h3 class="text-[#34260A] font-800 mb-2">How to Join</h3>
          <ul class="text-[#1F1706] text-sm space-y-2">
            <li>You can join at Ringcraft — just come along and complete a form.</li>
            <li>Or contact the Secretary, <strong>Ruth Waller</strong>, <a href="/P2432/contact-html" class="text-[#34260A] underline hover:no-underline">by email</a>.</li>
            <li>Forms will also be available for Beginner Obedience courses.</li>
          </ul>
        </div>
      </div>
      <div>
        <img
          src="/P2432/images/1013014-orig.png"
          alt="Membership form"
          width="781"
          height="566"
          loading="lazy"
          class="rounded-xl w-full"
        />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-[#34260A] py-14 px-4 text-center text-white">
    <h2 class="text-2xl font-800 mb-3">Ready to Join?</h2>
    <p class="text-white/80 mb-6 max-w-xl mx-auto">Pop along to any of our training classes to see what we do — you're welcome to watch without your dog. We'd love to meet you.</p>
    <a href="/P2432/contact-html" class="inline-block bg-white text-[#34260A] font-semibold px-8 py-3 rounded-full hover:bg-[#EFEEEB] transition-colors">Get in Touch</a>
  </section>

  <!-- Footer -->
  <footer class="bg-[#2A1E08] text-white py-12 px-4">
    <div class="max-w-6xl mx-auto grid sm:grid-cols-2 md:grid-cols-3 gap-8">
      <div>
        <h3 class="font-800 text-lg mb-3">Fleet &amp; District Dog Training Society</h3>
        <p class="text-white/70 text-sm">Crookham War Memorial Hall<br />Sandy Lane, Church Crookham<br />Fleet, Hampshire GU52 8LD</p>
        <p class="text-white/70 text-sm mt-2">
          <a href="tel:01252675912" class="hover:text-white">01252 675 912</a><br />
          <a href="mailto:fleetdogtrainingsociety@gmail.com" class="hover:text-white break-all">fleetdogtrainingsociety@gmail.com</a>
        </p>
      </div>
      <div>
        <h3 class="font-800 text-lg mb-3">Pages</h3>
        <ul class="space-y-1 text-sm text-white/70">
          <li><a href="/P2432" class="hover:text-white">Home</a></li>
          <li><a href="/P2432/about-us-html" class="hover:text-white">About Us</a></li>
          <li><a href="/P2432/membership-html" class="hover:text-white">Membership</a></li>
          <li><a href="/P2432/obedience-html" class="hover:text-white">Obedience</a></li>
          <li><a href="/P2432/ringcraft-html" class="hover:text-white">Ringcraft</a></li>
          <li><a href="/P2432/contact-html" class="hover:text-white">Contact</a></li>
        </ul>
      </div>
      <div>
        <h3 class="font-800 text-lg mb-3">Classes</h3>
        <p class="text-white/70 text-sm mb-1">🐾 Obedience — Wednesdays</p>
        <p class="text-white/70 text-sm mb-4">🏆 Ringcraft — Tuesdays</p>
        <p class="text-white/70 text-sm">Founded 1971 · Kennel Club registered</p>
      </div>
    </div>
    <div class="max-w-6xl mx-auto mt-8 pt-6 border-t border-white/10 text-center text-white/40 text-xs">
      &copy; {new Date().getFullYear()} Fleet and District Dog Training Society. This is a sample redesign built by <a href="/" class="underline hover:text-white/70">Biscuit Web</a>.
    </div>
  </footer>

  <script>
    const btn = document.getElementById('menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  </script>

</body>
</html>

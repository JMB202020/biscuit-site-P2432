---
import '../styles/site.css';
const site = {
  name: 'Fleet and District Dog Training Society',
  address: 'Crookham War Memorial Hall, Sandy Lane, Church Crookham, Fleet, Hampshire GU52 8LD',
  email: 'fleetdogtrainingsociety@gmail.com',
  phone: '01252 675 912',
};
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Fleet and District Dog Training Society – Dog Training Fleet Hampshire</title>
  <meta name="description" content="Friendly dog training classes in Fleet, Hampshire since 1971. Obedience on Wednesdays and Ringcraft on Tuesdays at Crookham War Memorial Hall." />
  <link rel="icon" href="/favicon.ico" />
</head>
<body>

  <!-- Preview banner -->
  <div class="bg-[#34260A] text-white text-center text-sm py-2 px-4">
    Preview redesign for Fleet and District Dog Training Society by
    <a href="https://biscuitweb.co.uk/activate?id=P2432&name=Fleet%20and%20District%20Dog%20Training%20Society" class="underline font-semibold hover:text-amber-300">Biscuit Web</a>
  </div>

  <!-- Navigation -->
  <header class="bg-white border-b border-[#C2BEB6] sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-4 flex items-center justify-between h-16">
      <a href="/P2432/" class="font-display font-800 text-[#34260A] text-lg leading-tight">
        Fleet &amp; District<br class="hidden sm:block" /> <span class="text-sm font-600">Dog Training Society</span>
      </a>
      <nav class="hidden md:flex items-center gap-6 text-sm font-semibold text-[#1F1706]">
        <a href="/P2432/" class="text-[#34260A] border-b-2 border-[#34260A] pb-0.5">Home</a>
        <a href="/P2432/about-us-html" class="hover:text-[#34260A] transition-colors">About Us</a>
        <a href="/P2432/membership-html" class="hover:text-[#34260A] transition-colors">Membership</a>
        <a href="/P2432/obedience-html" class="hover:text-[#34260A] transition-colors">Obedience</a>
        <a href="/P2432/ringcraft-html" class="hover:text-[#34260A] transition-colors">Ringcraft</a>
        <a href="/P2432/contact-html" class="bg-[#34260A] text-white px-4 py-1.5 rounded-full hover:bg-[#2A1E08] transition-colors">Contact</a>
      </nav>
      <button id="menu-btn" class="md:hidden p-2 rounded text-[#34260A]" aria-label="Open menu">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
    <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-[#C2BEB6] px-4 py-4 flex flex-col gap-3 text-sm font-semibold text-[#1F1706]">
      <a href="/P2432/" class="text-[#34260A]">Home</a>
      <a href="/P2432/about-us-html" class="hover:text-[#34260A]">About Us</a>
      <a href="/P2432/membership-html" class="hover:text-[#34260A]">Membership</a>
      <a href="/P2432/obedience-html" class="hover:text-[#34260A]">Obedience</a>
      <a href="/P2432/ringcraft-html" class="hover:text-[#34260A]">Ringcraft</a>
      <a href="/P2432/contact-html" class="hover:text-[#34260A]">Contact</a>
    </div>
  </header>

  <!-- Hero -->
  <section class="relative overflow-hidden min-h-[560px] flex items-center">
    <img
      src="/P2432/images/home-fleet-and-district-dog-training-society.jpg"
      alt="Dog training class at Fleet and District Dog Training Society"
      class="absolute inset-0 w-full h-full object-cover"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-black/70"></div>
    <div class="relative z-10 max-w-6xl mx-auto px-6 py-16 grid md:grid-cols-2 gap-10 items-center w-full">
      <div>
        <span class="inline-block bg-[#34260A] text-white text-sm font-semibold px-3 py-1 rounded-full mb-4">📍 Fleet, Hampshire</span>
        <h1 class="text-white text-4xl md:text-5xl font-800 leading-tight mb-4">Friendly Dog Training in Fleet</h1>
        <p class="text-white/90 text-lg mb-6">Your local dog training club for Fleet, Church Crookham (Hart) and North Hampshire. Founded 1971 and registered by The Kennel Club.</p>
        <div class="flex flex-wrap gap-3">
          <a href="/P2432/obedience-html" class="bg-[#34260A] text-white font-semibold px-6 py-3 rounded-full hover:bg-[#2A1E08] transition-colors">Obedience Classes</a>
          <a href="/P2432/ringcraft-html" class="bg-white text-[#34260A] font-semibold px-6 py-3 rounded-full hover:bg-[#EFEEEB] transition-colors">Ringcraft Classes</a>
        </div>
      </div>
      <div class="hidden md:flex flex-col gap-4">
        <img
          src="/P2432/images/puppy-class-number-3-june-2024-cropped-o.jpg"
          alt="Puppy training class"
          width="800"
          height="350"
          class="w-full rounded-xl object-cover aspect-video"
          fetchpriority="high"
        />
      </div>
    </div>
  </section>

  <!-- Quick info strip -->
  <section class="bg-[#34260A] text-white py-4 px-4">
    <div class="max-w-6xl mx-auto flex flex-wrap justify-center gap-x-10 gap-y-2 text-sm font-semibold text-center">
      <span>🐾 Obedience — Wednesdays</span>
      <span>🏆 Ringcraft — Tuesdays</span>
      <span>📍 Crookham War Memorial Hall, Fleet</span>
      <span>📞 <a href="tel:01252675912" class="underline hover:text-amber-300">01252 675 912</a></span>
    </div>
  </section>

  <!-- About / Intro -->
  <section class="bg-[#F5F4F3] py-16 px-4">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-[#34260A] text-3xl font-800 mb-4">About the Club</h2>
        <p class="text-[#1F1706] mb-4">Fleet and District Dog Training Society was founded in 1971 and offers basic dog training (Obedience on Wednesdays) and show ring training (Ringcraft, on Tuesdays).</p>
        <p class="text-[#1F1706] mb-4">Our instructors are experienced people, who offer sympathetic and kind training methods, encouraging members to achieve as much with their dogs as they wish.</p>
        <p class="text-[#1F1706] mb-6">We have a dedicated and enthusiastic committee who run the club on a purely voluntary basis. All proceeds from courses and ringcraft are used to run and maintain the club, and we make substantial donations to dog charities too.</p>
        <ul class="space-y-2 text-[#1F1706]">
          <li class="flex items-start gap-2"><span class="text-[#34260A] font-bold mt-0.5">✓</span> Looking for friendly dog training classes in the evenings?</li>
          <li class="flex items-start gap-2"><span class="text-[#34260A] font-bold mt-0.5">✓</span> Like to join pet dog training classes with local people?</li>
          <li class="flex items-start gap-2"><span class="text-[#34260A] font-bold mt-0.5">✓</span> Want to show your pedigree dog?</li>
        </ul>
        <p class="mt-6 text-[#1F1706] italic">You can pop along to any training class, without your dog, just to watch — we'd be delighted to meet you.</p>
      </div>
      <div class="flex flex-col gap-4 items-center">
        <img
          src="/P2432/images/kcgc-july-2025-bronze-orig.jpg"
          alt="Kennel Club Good Citizen Bronze award"
          width="600"
          height="450"
          loading="lazy"
          class="rounded-xl w-full object-cover"
        />
        <div class="flex gap-4">
          <img src="/P2432/images/6606095.png" alt="Award badge" width="150" height="90" loading="lazy" class="rounded" />
          <img src="/P2432/images/7242448.png" alt="Award badge" width="150" height="90" loading="lazy" class="rounded" />
        </div>
      </div>
    </div>
  </section>

  <!-- Classes -->
  <section class="bg-[#EFEEEB] py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-[#34260A] text-3xl font-800 text-center mb-10">Our Training Classes</h2>
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Ringcraft -->
        <div class="bg-white rounded-2xl overflow-hidden shadow-sm border border-[#C2BEB6]">
          <div class="relative overflow-hidden aspect-video">
            <img src="/P2432/images/ringcraft-html-0.jpg" alt="Ringcraft training class" class="w-full h-full object-cover" loading="lazy" width="752" height="160" />
            <div class="absolute inset-0 bg-black/50"></div>
            <div class="absolute bottom-4 left-4">
              <span class="bg-[#34260A] text-white text-xs font-semibold px-3 py-1 rounded-full">Tuesdays</span>
            </div>
          </div>
          <div class="p-6">
            <h3 class="text-[#34260A] text-xl font-800 mb-3">Ringcraft</h3>
            <p class="text-[#1F1706] mb-4">Learn to handle your dog for the show ring with experienced trainers. Lots of tips from experienced handlers too!</p>
            <a href="/P2432/ringcraft-html" class="inline-block bg-[#34260A] text-white font-semibold px-5 py-2 rounded-full text-sm hover:bg-[#2A1E08] transition-colors">Learn More</a>
          </div>
        </div>
        <!-- Obedience -->
        <div class="bg-white rounded-2xl overflow-hidden shadow-sm border border-[#C2BEB6]">
          <div class="relative overflow-hidden aspect-video">
            <img src="/P2432/images/obedience-html-0.jpg" alt="Obedience training class" class="w-full h-full object-cover" loading="lazy" width="752" height="160" />
            <div class="absolute inset-0 bg-black/50"></div>
            <div class="absolute bottom-4 left-4">
              <span class="bg-[#34260A] text-white text-xs font-semibold px-3 py-1 rounded-full">Wednesdays</span>
            </div>
          </div>
          <div class="p-6">
            <h3 class="text-[#34260A] text-xl font-800 mb-3">Obedience</h3>
            <p class="text-[#1F1706] mb-2">Forge a strong bond with your dog, for a more fulfilling and rewarding relationship. Small classes with experienced trainers.</p>
            <p class="text-[#34260A] font-semibold text-sm mb-4">Now taking bookings — book early to avoid disappointment.</p>
            <a href="/P2432/obedience-html" class="inline-block bg-[#34260A] text-white font-semibold px-5 py-2 rounded-full text-sm hover:bg-[#2A1E08] transition-colors">Learn More</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Find us -->
  <section class="bg-[#F5F4F3] py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-[#34260A] text-3xl font-800 mb-4">Find Us</h2>
      <p class="text-[#1F1706] text-lg mb-6">Crookham War Memorial Hall<br />Sandy Lane, Church Crookham, Fleet, Hampshire <strong>GU52 8LD</strong></p>
      <a href="/P2432/contact-html" class="inline-block bg-[#34260A] text-white font-semibold px-8 py-3 rounded-full hover:bg-[#2A1E08] transition-colors">Get in Touch</a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-[#2A1E08] text-white py-12 px-4">
    <div class="max-w-6xl mx-auto grid sm:grid-cols-2 md:grid-cols-3 gap-8">
      <div>
        <h3 class="font-800 text-lg mb-3">Fleet &amp; District Dog Training Society</h3>
        <p class="text-white/70 text-sm">Crookham War Memorial Hall<br />Sandy Lane, Church Crookham<br />Fleet, Hampshire GU52 8LD</p>
        <p class="text-white/70 text-sm mt-2">
          <a href="tel:01252675912" class="hover:text-white">01252 675 912</a><br />
          <a href="mailto:fleetdogtrainingsociety@gmail.com" class="hover:text-white break-all">fleetdogtrainingsociety@gmail.com</a>
        </p>
      </div>
      <div>
        <h3 class="font-800 text-lg mb-3">Pages</h3>
        <ul class="space-y-1 text-sm text-white/70">
          <li><a href="/P2432/" class="hover:text-white">Home</a></li>
          <li><a href="/P2432/about-us-html" class="hover:text-white">About Us</a></li>
          <li><a href="/P2432/membership-html" class="hover:text-white">Membership</a></li>
          <li><a href="/P2432/obedience-html" class="hover:text-white">Obedience</a></li>
          <li><a href="/P2432/ringcraft-html" class="hover:text-white">Ringcraft</a></li>
          <li><a href="/P2432/contact-html" class="hover:text-white">Contact</a></li>
        </ul>
      </div>
      <div>
        <h3 class="font-800 text-lg mb-3">Classes</h3>
        <p class="text-white/70 text-sm mb-1">🐾 Obedience — Wednesdays</p>
        <p class="text-white/70 text-sm mb-4">🏆 Ringcraft — Tuesdays</p>
        <p class="text-white/70 text-sm">Founded 1971 · Kennel Club registered</p>
      </div>
    </div>
    <div class="max-w-6xl mx-auto mt-8 pt-6 border-t border-white/10 text-center text-white/40 text-xs">
      &copy; {new Date().getFullYear()} Fleet and District Dog Training Society. This is a sample redesign built by <a href="/" class="underline hover:text-white/70">Biscuit Web</a>.
    </div>
  </footer>

  <script>
    const btn = document.getElementById('menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  </script>

</body>
</html>

---
import '../styles/site.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>About Us – Fleet and District Dog Training Society</title>
  <meta name="description" content="Learn about Fleet and District Dog Training Society — founded 1971, Kennel Club registered, run entirely by volunteers in Fleet, Hampshire." />
</head>
<body>

  <!-- Preview Banner -->
    <div style="background:#B45309;color:white;padding:10px 16px;text-align:center;font-size:14px;position:sticky;top:0;z-index:50"><div style="max-width:56rem;margin:0 auto;display:flex;align-items:center;justify-content:center;gap:16px;flex-wrap:wrap"><span>Preview redesign for <strong>Fleet and District Dog Training Society</strong></span><a href="https://biscuitweb.co.uk/activate?id=P2432&amp;name=Fleet%20and%20District%20Dog%20Training%20Society" style="display:inline-flex;align-items:center;padding:4px 16px;background:white;color:#B45309;font-weight:700;font-size:12px;border-radius:9999px;text-decoration:none">Like it? Just £20/month</a></div></div>

    <div>
        <img
          src="/P2432/images/4564.png"
          alt="Fleet and District Dog Training Society committee"
          width="500"
          height="362"
          loading="lazy"
          class="rounded-xl w-full"
        />
      </div>
    </div>
  </section>

  <!-- Officers & Committee -->
  <section class="bg-[#EFEEEB] py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-[#34260A] text-2xl font-800 mb-8 text-center">Officers &amp; Committee Members</h2>
      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">
        <div class="bg-white rounded-xl p-5 border border-[#C2BEB6]">
          <p class="text-[#34260A] font-800 text-sm mb-1">Secretary</p>
          <p class="text-[#1F1706]">Ruth Waller</p>
          <p class="text-[#1F1706] text-sm mt-1">
            <a href="/P2432/contact-html" class="text-[#34260A] underline hover:no-underline">Contact the Secretary</a>
          </p>
        </div>
        <div class="bg-white rounded-xl p-5 border border-[#C2BEB6]">
          <p class="text-[#34260A] font-800 text-sm mb-1">Training Bookings</p>
          <p class="text-[#1F1706]">Janet</p>
          <p class="text-[#1F1706] text-sm mt-1">
            <a href="mailto:fleetdogtrainingsociety@gmail.com" class="text-[#34260A] underline hover:no-underline break-all">fleetdogtrainingsociety@gmail.com</a>
          </p>
        </div>
        <div class="bg-white rounded-xl p-5 border border-[#C2BEB6]">
          <p class="text-[#34260A] font-800 text-sm mb-1">Committee</p>
          <p class="text-[#1F1706] text-sm">Run entirely on a voluntary basis. All proceeds go back into the club and to our chosen dog charities.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-[#2A1E08] text-white py-12 px-4">
    <div class="max-w-6xl mx-auto grid sm:grid-cols-2 md:grid-cols-3 gap-8">
      <div>
        <h3 class="font-800 text-lg mb-3">Fleet &amp; District Dog Training Society</h3>
        <p class="text-white/70 text-sm">Crookham War Memorial Hall<br />Sandy Lane, Church Crookham<br />Fleet, Hampshire GU52 8LD</p>
        <p class="text-white/70 text-sm mt-2">
          <a href="tel:01252675912" class="hover:text-white">01252 675 912</a><br />
          <a href="mailto:fleetdogtrainingsociety@gmail.com" class="hover:text-white break-all">fleetdogtrainingsociety@gmail.com</a>
        </p>
      </div>
      <div>
        <h3 class="font-800 text-lg mb-3">Pages</h3>
        <ul class="space-y-1 text-sm text-white/70">
          <li><a href="/P2432/" class="hover:text-white">Home</a></li>
          <li><a href="/P2432/about-us-html" class="hover:text-white">About Us</a></li>
          <li><a href="/P2432/membership-html" class="hover:text-white">Membership</a></li>
          <li><a href="/P2432/obedience-html" class="hover:text-white">Obedience</a></li>
          <li><a href="/P2432/ringcraft-html" class="hover:text-white">Ringcraft</a></li>
          <li><a href="/P2432/contact-html" class="hover:text-white">Contact</a></li>
        </ul>
      </div>
      <div>
        <h3 class="font-800 text-lg mb-3">Classes</h3>
        <p class="text-white/70 text-sm mb-1">🐾 Obedience — Wednesdays</p>
        <p class="text-white/70 text-sm mb-4">🏆 Ringcraft — Tuesdays</p>
        <p class="text-white/70 text-sm">Founded 1971 · Kennel Club registered</p>
      </div>
    </div>
    <div class="max-w-6xl mx-auto mt-8 pt-6 border-t border-white/10 text-center text-white/40 text-xs">
      &copy; {new Date().getFullYear()} Fleet and District Dog Training Society. This is a sample redesign built by <a href="/" class="underline hover:text-white/70">Biscuit Web</a>.
    </div>
  </footer>

  <script>
    const btn = document.getElementById('menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  </script>

</body>
</html>

---
import '../styles/site.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Contact Us – Fleet and District Dog Training Society</title>
  <meta name="description" content="Contact Fleet and District Dog Training Society. Find us at Crookham War Memorial Hall, Sandy Lane, Church Crookham, Fleet, GU52 8LD." />
</head>
<body>

  <!-- Preview banner -->
  <div class="bg-[#34260A] text-white text-center text-sm py-2 px-4">
    Preview redesign for Fleet and District Dog Training Society by
    <a href="https://biscuitweb.co.uk/activate?id=P2432&name=Fleet%20and%20District%20Dog%20Training%20Society" class="underline font-semibold hover:text-amber-300">Biscuit Web</a>
  </div>

  <!-- Navigation -->
  <header class="bg-white border-b border-[#C2BEB6] sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-4 flex items-center justify-between h-16">
      <a href="/P2432" class="font-display font-800 text-[#34260A] text-lg leading-tight">
        Fleet &amp; District<br class="hidden sm:block" /> <span class="text-sm font-600">Dog Training Society</span>
      </a>
      <nav class="hidden md:flex items-center gap-6 text-sm font-semibold text-[#1F1706]">
        <a href="/P2432" class="hover:text-[#34260A] transition-colors">Home</a>
        <a href="/P2432/about-us-html" class="hover:text-[#34260A] transition-colors">About Us</a>
        <a href="/P2432/membership-html" class="hover:text-[#34260A] transition-colors">Membership</a>
        <a href="/P2432/obedience-html" class="hover:text-[#34260A] transition-colors">Obedience</a>
        <a href="/P2432/ringcraft-html" class="hover:text-[#34260A] transition-colors">Ringcraft</a>
        <a href="/P2432/contact-html" class="bg-[#34260A] text-white px-4 py-1.5 rounded-full">Contact</a>
      </nav>
      <button id="menu-btn" class="md:hidden p-2 rounded text-[#34260A]" aria-label="Open menu">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
    <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-[#C2BEB6] px-4 py-4 flex flex-col gap-3 text-sm font-semibold text-[#1F1706]">
      <a href="/P2432" class="hover:text-[#34260A]">Home</a>
      <a href="/P2432/about-us-html" class="hover:text-[#34260A]">About Us</a>
      <a href="/P2432/membership-html" class="hover:text-[#34260A]">Membership</a>
      <a href="/P2432/obedience-html" class="hover:text-[#34260A]">Obedience</a>
      <a href="/P2432/ringcraft-html" class="hover:text-[#34260A]">Ringcraft</a>
      <a href="/P2432/contact-html" class="text-[#34260A]">Contact</a>
    </div>
  </header>

  <!-- Page hero -->
  <section class="relative overflow-hidden min-h-[280px] flex items-end">
    <img
      src="/P2432/images/contact-html-0.jpg"
      alt="Contact Fleet and District Dog Training Society"
      class="absolute inset-0 w-full h-full object-cover"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-black/70"></div>
    <div class="relative z-10 max-w-6xl mx-auto px-6 py-10 w-full">
      <h1 class="text-white text-4xl font-800">Contact Us</h1>
      <p class="text-white/80 mt-2">We'd love to hear from you</p>
    </div>
  </section>

  <!-- Contact content -->
  <section class="bg-[#F5F4F3] py-16 px-4">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-12">

      <!-- Form -->
      <div>
        <h2 class="text-[#34260A] text-2xl font-800 mb-3">Send Us a Message</h2>
        <p class="text-[#1F1706] mb-6">To contact us, please fill in the form and we'll get back to you very soon. Alternatively, you can pop along to any training class, without your dog to watch — we'd be delighted to meet you.</p>

        <form action="https://formspree.io/f/mwvaaojq" method="POST" class="space-y-4">
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="first-name" class="block text-sm font-semibold text-[#1F1706] mb-1">First name *</label>
              <input type="text" id="first-name" name="first_name" required class="w-full border border-[#C2BEB6] rounded-lg px-4 py-2.5 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-[#34260A]" />
            </div>
            <div>
              <label for="last-name" class="block text-sm font-semibold text-[#1F1706] mb-1">Last name *</label>
              <input type="text" id="last-name" name="last_name" required class="w-full border border-[#C2BEB6] rounded-lg px-4 py-2.5 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-[#34260A]" />
            </div>
          </div>
          <div>
            <label for="email" class="block text-sm font-semibold text-[#1F1706] mb-1">Email *</label>
            <input type="email" id="email" name="email" required class="w-full border border-[#C2BEB6] rounded-lg px-4 py-2.5 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-[#34260A]" />
          </div>
          <div>
            <label for="phone" class="block text-sm font-semibold text-[#1F1706] mb-1">Phone number *</label>
            <input type="tel" id="phone" name="phone" required class="w-full border border-[#C2BEB6] rounded-lg px-4 py-2.5 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-[#34260A]" />
          </div>
          <div>
            <label for="comment" class="block text-sm font-semibold text-[#1F1706] mb-1">Message *</label>
            <textarea id="comment" name="comment" rows="5" required class="w-full border border-[#C2BEB6] rounded-lg px-4 py-2.5 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-[#34260A] resize-none"></textarea>
          </div>
          <button type="submit" class="w-full bg-[#34260A] text-white font-semibold py-3 rounded-full hover:bg-[#2A1E08] transition-colors">Submit</button>
        </form>
      </div>

      <!-- Venue info -->
      <div>
        <h2 class="text-[#34260A] text-2xl font-800 mb-3">Dog Training Classes Venue</h2>
        <div class="bg-white rounded-xl border border-[#C2BEB6] p-6 mb-6">
          <p class="font-semibold text-[#1F1706] mb-1">Crookham War Memorial Hall</p>
          <p class="text-[#1F1706]">Sandy Lane<br />Church Crookham<br />Fleet<br />Hampshire GU52 8LD</p>
          <div class="mt-4 pt-4 border-t border-[#EFEEEB] space-y-2">
            <p class="text-sm text-[#1F1706]">
              📞 <a href="tel:01252675912" class="text-[#34260A] font-semibold hover:underline">01252 675 912</a>
            </p>
            <p class="text-sm text-[#1F1706]">
              ✉️ <a href="mailto:fleetdogtrainingsociety@gmail.com" class="text-[#34260A] font-semibold hover:underline break-all">fleetdogtrainingsociety@gmail.com</a>
            </p>
          </div>
        </div>

        <div class="bg-[#EFEEEB] rounded-xl border border-[#C2BEB6] p-5 mb-6">
          <h3 class="text-[#34260A] font-800 mb-3">Class Times</h3>
          <p class="text-[#1F1706] text-sm mb-1">🐾 <strong>Obedience</strong> — Wednesdays evenings</p>
          <p class="text-[#1F1706] text-sm">🏆 <strong>Ringcraft</strong> — Tuesday evenings</p>
        </div>

        <!-- Embedded map via iframe using coordinates from scraped data -->
        <div class="rounded-xl overflow-hidden border border-[#C2BEB6]">
          <iframe
            src="https://maps.google.com/maps?q=51.25914419999999,-0.8382113000000118&z=15&output=embed"
            width="100%"
            height="250"
            loading="lazy"
            title="Crookham War Memorial Hall map"
            style="border:0;"
          ></iframe>
        </div>
      </div>

    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-[#2A1E08] text-white py-12 px-4">
    <div class="max-w-6xl mx-auto grid sm:grid-cols-2 md:grid-cols-3 gap-8">
      <div>
        <h3 class="font-800 text-lg mb-3">Fleet &amp; District Dog Training Society</h3>
        <p class="text-white/70 text-sm">Crookham War Memorial Hall<br />Sandy Lane, Church Crookham<br />Fleet, Hampshire GU52 8LD</p>
        <p class="text-white/70 text-sm mt-2">
          <a href="tel:01252675912" class="hover:text-white">01252 675 912</a><br />
          <a href="mailto:fleetdogtrainingsociety@gmail.com" class="hover:text-white break-all">fleetdogtrainingsociety@gmail.com</a>
        </p>
      </div>
      <div>
        <h3 class="font-800 text-lg mb-3">Pages</h3>
        <ul class="space-y-1 text-sm text-white/70">
          <li><a href="/P2432" class="hover:text-white">Home</a></li>
          <li><a href="/P2432/about-us-html" class="hover:text-white">About Us</a></li>
          <li><a href="/P2432/membership-html" class="hover:text-white">Membership</a></li>
          <li><a href="/P2432/obedience-html" class="hover:text-white">Obedience</a></li>
          <li><a href="/P2432/ringcraft-html" class="hover:text-white">Ringcraft</a></li>
          <li><a href="/P2432/contact-html" class="hover:text-white">Contact</a></li>
        </ul>
      </div>
      <div>
        <h3 class="font-800 text-lg mb-3">Classes</h3>
        <p class="text-white/70 text-sm mb-1">🐾 Obedience — Wednesdays</p>
        <p class="text-white/70 text-sm mb-4">🏆 Ringcraft — Tuesdays</p>
        <p class="text-white/70 text-sm">Founded 1971 · Kennel Club registered</p>
      </div>
    </div>
    <div class="max-w-6xl mx-auto mt-8 pt-6 border-t border-white/10 text-center text-white/40 text-xs">
      &copy; {new Date().getFullYear()} Fleet and District Dog Training Society. This is a sample redesign built by <a href="/" class="underline hover:text-white/70">Biscuit Web</a>.
    </div>
  </footer>

  <script>
    const btn = document.getElementById('menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  </script>

</body>
</html>

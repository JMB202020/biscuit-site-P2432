---
import '/src/styles/redesigns/P2432.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Ringcraft Classes – Fleet and District Dog Training Society</title>
  <meta name="description" content="Show ring training (Ringcraft) every Tuesday at Crookham War Memorial Hall, Fleet. Learn to handle and present your dog with experienced trainers." />
</head>
<body>

  <!-- Preview banner -->
  <div class="bg-[#34260A] text-white text-center text-sm py-2 px-4">
    Preview redesign for Fleet and District Dog Training Society by
    <a href="https://biscuitweb.co.uk/activate?id=P2432&name=Fleet%20and%20District%20Dog%20Training%20Society" class="underline font-semibold hover:text-amber-300">Biscuit Web</a>
  </div>

  <!-- Navigation -->
  <header class="bg-white border-b border-[#C2BEB6] sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-4 flex items-center justify-between h-16">
      <a href="/P2432/" class="font-display font-800 text-[#34260A] text-lg leading-tight">
        Fleet &amp; District<br class="hidden sm:block" /> <span class="text-sm font-600">Dog Training Society</span>
      </a>
      <nav class="hidden md:flex items-center gap-6 text-sm font-semibold text-[#1F1706]">
        <a href="/P2432/" class="hover:text-[#34260A] transition-colors">Home</a>
        <a href="/P2432/about-us-html" class="hover:text-[#34260A] transition-colors">About Us</a>
        <a href="/P2432/membership-html" class="hover:text-[#34260A] transition-colors">Membership</a>
        <a href="/P2432/obedience-html" class="hover:text-[#34260A] transition-colors">Obedience</a>
        <a href="/P2432/ringcraft-html" class="text-[#34260A] border-b-2 border-[#34260A] pb-0.5">Ringcraft</a>
        <a href="/P2432/contact-html" class="bg-[#34260A] text-white px-4 py-1.5 rounded-full hover:bg-[#2A1E08] transition-colors">Contact</a>
      </nav>
      <button id="menu-btn" class="md:hidden p-2 rounded text-[#34260A]" aria-label="Open menu">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
    <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-[#C2BEB6] px-4 py-4 flex flex-col gap-3 text-sm font-semibold text-[#1F1706]">
      <a href="/P2432/" class="hover:text-[#34260A]">Home</a>
      <a href="/P2432/about-us-html" class="hover:text-[#34260A]">About Us</a>
      <a href="/P2432/membership-html" class="hover:text-[#34260A]">Membership</a>
      <a href="/P2432/obedience-html" class="hover:text-[#34260A]">Obedience</a>
      <a href="/P2432/ringcraft-html" class="text-[#34260A]">Ringcraft</a>
      <a href="/P2432/contact-html" class="hover:text-[#34260A]">Contact</a>
    </div>
  </header>

  <!-- Page hero -->
  <section class="relative overflow-hidden min-h-[300px] flex items-end">
    <img
      src="/P2432/images/ringcraft-html-0.jpg"
      alt="Ringcraft show ring training"
      class="absolute inset-0 w-full h-full object-cover"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-black/70"></div>
    <div class="relative z-10 max-w-6xl mx-auto px-6 py-10 w-full">
      <h1 class="text-white text-4xl font-800">Ringcraft Classes</h1>
      <p class="text-white/80 mt-2">Show ring training every Tuesday at Crookham War Memorial Hall</p>
    </div>
  </section>

  <!-- Gallery of show dogs -->
  <section class="bg-[#F5F4F3] py-10 px-4">
    <div class="max-w-5xl mx-auto grid grid-cols-3 gap-4">
      <div class="aspect-square overflow-hidden rounded-xl">
        <img src="/P2432/images/6282956.jpg" alt="Show dog ringcraft" width="250" height="199" loading="lazy" class="w-full h-full object-cover" />
      </div>
      <div class="aspect-square overflow-hidden rounded-xl">
        <img src="/P2432/images/4634661.jpg" alt="Dog in show ring" width="214" height="196" loading="lazy" class="w-full h-full object-cover" />
      </div>
      <div class="aspect-square overflow-hidden rounded-xl">
        <img src="/P2432/images/8173162.jpg" alt="Ringcraft training" width="215" height="199" loading="lazy" class="w-full h-full object-cover" />
      </div>
    </div>
  </section>

  <!-- Ringcraft intro -->
  <section class="bg-[#F5F4F3] pb-16 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-[#34260A] text-2xl font-800 mb-6">Ringcraft Classes (classes for show training)</h2>
      <div class="grid md:grid-cols-2 gap-10">
        <div>
          <p class="text-[#1F1706] mb-4">Many people enjoy showing their dogs as it is a great opportunity not only to show off your dog but to meet friends old and new.</p>
          <p class="text-[#1F1706] mb-4">At classes we help to show you the best way to handle and present your dog in the show ring. The breeder of your dog will almost certainly also be able to help you get started and being a member of your breed club will offer you access to further show information.</p>
          <ul class="space-y-3 mb-6">
            <li class="flex items-start gap-2 text-[#1F1706]">
              <span class="text-[#34260A] font-bold mt-0.5">✓</span> Dog papers and show schedules are made available at each class for members to make use of
            </li>
            <li class="flex items-start gap-2 text-[#1F1706]">
              <span class="text-[#34260A] font-bold mt-0.5">✓</span> We will occasionally run matches, which will be notified in advance with a guest judge
            </li>
          </ul>
        </div>
        <div>
          <div class="bg-white rounded-xl border border-[#C2BEB6] p-5 mb-4">
            <h3 class="text-[#34260A] font-800 mb-3">Training and Trophies</h3>
            <p class="text-[#1F1706] text-sm">If you do decide to show your dog, we wish you all the very best of luck. Remember, whatever the judge thinks, you always take the best dog home with you.</p>
          </div>
          <div class="bg-[#EFEEEB] rounded-xl border border-[#C2BEB6] p-5">
            <h3 class="text-[#34260A] font-800 mb-3 text-sm">Useful Resources</h3>
            <ul class="text-sm text-[#1F1706] space-y-1">
              <li>The Kennel Club: <a href="https://www.thekennelclub.org.uk" target="_blank" rel="noopener" class="text-[#34260A] underline hover:no-underline">thekennelclub.org.uk</a></li>
              <li>Show details: <a href="https://www.highampress.co.uk" target="_blank" rel="noopener" class="text-[#34260A] underline hover:no-underline">highampress.co.uk</a></li>
              <li>Show details: <a href="https://www.fossedata.co.uk" target="_blank" rel="noopener" class="text-[#34260A] underline hover:no-underline">fossedata.co.uk</a></li>
              <li>Canine newspaper: <a href="https://www.ourdogs.co.uk" target="_blank" rel="noopener" class="text-[#34260A] underline hover:no-underline">ourdogs.co.uk</a></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Types of shows -->
  <section class="bg-[#EFEEEB] py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-[#34260A] text-2xl font-800 mb-8 text-center">Types of Dog Shows</h2>
      <div class="grid sm:grid-cols-3 gap-6">
        <div class="bg-white rounded-xl p-6 border border-[#C2BEB6]">
          <h3 class="text-[#34260A] font-800 mb-2">Companion Show</h3>
          <p class="text-[#1F1706] text-sm">A local village show where you can turn up and enter on the day. Held in aid of charity and licensed by the Kennel Club. Advertised in local papers.</p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-[#C2BEB6]">
          <h3 class="text-[#34260A] font-800 mb-2">Open Show</h3>
          <p class="text-[#1F1706] text-sm">The next level up. A considerable number are held across the country. Local canine societies generally hold one or two shows per year, open to all breeds. Must be entered in advance.</p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-[#C2BEB6]">
          <h3 class="text-[#34260A] font-800 mb-2">Championship Show</h3>
          <p class="text-[#1F1706] text-sm">The highest level. With the right placings, you can qualify your dog to compete at Crufts. Sufficient success makes your dog a Show Champion.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-[#34260A] py-14 px-4 text-white text-center">
    <h2 class="text-2xl font-800 mb-3">Interested in Ringcraft?</h2>
    <p class="text-white/80 mb-6 max-w-xl mx-auto">Come along on a Tuesday evening to see what we do. You're welcome to pop in without your dog first.</p>
    <a href="/P2432/contact-html" class="inline-block bg-white text-[#34260A] font-semibold px-8 py-3 rounded-full hover:bg-[#EFEEEB] transition-colors">Get in Touch</a>
  </section>

  <!-- Footer -->
  <footer class="bg-[#2A1E08] text-white py-12 px-4">
    <div class="max-w-6xl mx-auto grid sm:grid-cols-2 md:grid-cols-3 gap-8">
      <div>
        <h3 class="font-800 text-lg mb-3">Fleet &amp; District Dog Training Society</h3>
        <p class="text-white/70 text-sm">Crookham War Memorial Hall<br />Sandy Lane, Church Crookham<br />Fleet, Hampshire GU52 8LD</p>
        <p class="text-white/70 text-sm mt-2">
          <a href="tel:01252675912" class="hover:text-white">01252 675 912</a><br />
          <a href="mailto:fleetdogtrainingsociety@gmail.com" class="hover:text-white break-all">fleetdogtrainingsociety@gmail.com</a>
        </p>
      </div>
      <div>
        <h3 class="font-800 text-lg mb-3">Pages</h3>
        <ul class="space-y-1 text-sm text-white/70">
          <li><a href="/P2432/" class="hover:text-white">Home</a></li>
          <li><a href="/P2432/about-us-html" class="hover:text-white">About Us</a></li>
          <li><a href="/P2432/membership-html" class="hover:text-white">Membership</a></li>
          <li><a href="/P2432/obedience-html" class="hover:text-white">Obedience</a></li>
          <li><a href="/P2432/ringcraft-html" class="hover:text-white">Ringcraft</a></li>
          <li><a href="/P2432/contact-html" class="hover:text-white">Contact</a></li>
        </ul>
      </div>
      <div>
        <h3 class="font-800 text-lg mb-3">Classes</h3>
        <p class="text-white/70 text-sm mb-1">🐾 Obedience — Wednesdays</p>
        <p class="text-white/70 text-sm mb-4">🏆 Ringcraft — Tuesdays</p>
        <p class="text-white/70 text-sm">Founded 1971 · Kennel Club registered</p>
      </div>
    </div>
    <div class="max-w-6xl mx-auto mt-8 pt-6 border-t border-white/10 text-center text-white/40 text-xs">
      &copy; {new Date().getFullYear()} Fleet and District Dog Training Society. This is a sample redesign built by <a href="/" class="underline hover:text-white/70">Biscuit Web</a>.
    </div>
  </footer>

  <script>
    const btn = document.getElementById('menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  </script>

</body>
</html>
